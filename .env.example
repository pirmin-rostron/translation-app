# Translation provider: "openai" to use OpenAI, leave empty for mock
TRANSLATION_PROVIDER=openai

# Required when TRANSLATION_PROVIDER=openai
OPENAI_API_KEY=

# Optional OpenAI embedding model used for semantic translation memory
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Segments per API call (default 5)
TRANSLATION_BATCH_SIZE=5

# Similarity threshold for semantic translation-memory reuse (0.0 - 1.0)
SEMANTIC_MEMORY_THRESHOLD=0.80

# Default customer identifier applied when one is not provided
DEFAULT_CUSTOMER_ID=default

# Backend export output directory
EXPORT_DIR=exports

# Frontend API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000
