# =============================================================================
# .env.example — copy to .env and fill in real values
# Never commit .env to git.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://translation:translation@postgres:5432/translation

# --- Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-in-production

# --- Translation Provider ---
# "claude" (default) or "mock" for local testing without API calls
TRANSLATION_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...

# --- Voyage AI (embeddings / semantic memory) ---
VOYAGE_API_KEY=pa-...

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- Storage ---
# "local" stores uploads on disk; "s3" streams to/from S3
STORAGE_BACKEND=local

# Required when STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2
S3_BUCKET_NAME=

# --- Email (not yet implemented) ---
# Required for invite emails and password reset delivery once email is wired up.
AWS_SES_REGION=ap-southeast-2
EMAIL_FROM=noreply@helvara.io

# --- Celery worker ---
# Set automatically in docker-compose for the worker service — not needed in .env
# PYTHONPATH=/app
